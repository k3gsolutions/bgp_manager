# Copie para `.env` na raiz do repositório (o ficheiro `.env` não deve ser versionado).
# Variáveis usadas por `docker-compose.yml`.

POSTGRES_USER=bgpuser
POSTGRES_PASSWORD=
POSTGRES_DB=bgpmanager

APP_ENV=development
# Deve refletir a versão em produção; alinhar com tag semver no GitHub (ex. v0.1.1) para updates remotos.
APP_VERSION=0.1.1
JWT_SECRET=
# Gerar: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_PASSWORD=
