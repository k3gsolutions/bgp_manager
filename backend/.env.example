# Database — desenvolvimento local (SQLite, sem credenciais em URL)
DATABASE_URL=sqlite+aiosqlite:///./bgpmanager.db
#
# PostgreSQL (ex.: com docker-compose na raiz do projeto): defina utilizador/senha fortes e use asyncpg
# DATABASE_URL=postgresql+asyncpg://SEU_USER:SUA_SENHA_FORTE@localhost:5432/bgpmanager

# Security — obrigatório antes de guardar equipamentos com senha SSH:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT — em APP_ENV=development, se vazio o backend usa um segredo fixo APENAS para dev (nunca em produção).
# Em APP_ENV=production o arranque falha se JWT_SECRET estiver vazio, for curto (<32) ou for o valor de dev.
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# Primeiro utilizador: só é criado se a tabela users estiver vazia (uma vez). Defina palavra-passe forte.
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_PASSWORD=

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS: origens extras (ex.: http://192.168.1.5:5174) se abrir o Vite pelo IP da LAN
CORS_EXTRA_ORIGINS=
