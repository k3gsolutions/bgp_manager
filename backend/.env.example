# Database — desenvolvimento local (SQLite, sem credenciais em URL)
DATABASE_URL=sqlite+aiosqlite:///./bgpmanager.db
#
# PostgreSQL (ex.: com docker-compose na raiz do projeto): defina utilizador/senha fortes e use asyncpg
# DATABASE_URL=postgresql+asyncpg://SEU_USER:SUA_SENHA_FORTE@localhost:5432/bgpmanager

# Security — obrigatório antes de guardar equipamentos com senha SSH:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# JWT — em APP_ENV=development, se vazio o backend usa um segredo fixo APENAS para dev (nunca em produção).
# Em APP_ENV=production o arranque falha se JWT_SECRET estiver vazio, for curto (<32) ou for o valor de dev.
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440

# Primeiro utilizador: só é criado se a tabela users estiver vazia (uma vez). Defina palavra-passe forte.
BOOTSTRAP_SUPERADMIN_USERNAME=superadmin
BOOTSTRAP_SUPERADMIN_PASSWORD=

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
# Versão exibida e usada no update remoto; alinhar com tag GitHub (ex. v0.1.1) e com frontend em produção.
APP_VERSION=0.1.1

# Máximo de snapshots ``display current-configuration`` por equipamento (mais antigos apagados).
# CONFIG_SNAPSHOT_RETENTION=30
# Horas entre snapshots no equipamento (evita ``display current-configuration`` a cada consulta SSH).
# CONFIG_SNAPSHOT_REFRESH_HOURS=1

# CORS: origens extras (lista separada por vírgula). Em APP_ENV=development o backend já aceita
# localhost/127.0.0.1/::1 em qualquer porta e redes privadas típicas (RFC1918) para o Vite.
# O navegador envia Origin = URL da página (ex.: http://127.0.0.1:5174), nunca a URL do API (:8000).
CORS_EXTRA_ORIGINS=

# Atualização do sistema (opcional): comandos de restart após update automático
# UPDATE_BACKEND_RESTART_CMD=
# UPDATE_FRONTEND_RESTART_CMD=
